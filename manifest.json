{
  "manifest_version": 3,
  "name": "Collect&Go - Totaux par catégorie",
  "version": "1.0.0",
  "description": "Affiche le total des prix par catégorie dans le chariot Collect&Go (à côté du compteur de produits).",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.collectandgo.be/*/chariot",
        "*://www.collectandgo.be/*/winkelwagen"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
