{
  "manifest_version": 3,
  "name": "Totaux par rayon — pour Collect&Go",
  "version": "1.0.0",
  "description": "Affiche le total des prix par rayon dans le chariot Collect&Go. Extension non officielle, sans affiliation avec Collect&Go / Colruyt Group.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Totaux par rayon — réglages",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.collectandgo.be/*/chariot",
        "*://www.collectandgo.be/*/winkelwagen"
      ],
      "js": ["pure.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
